rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read access for portfolio assets and downloadable files.
    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /downloads/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
